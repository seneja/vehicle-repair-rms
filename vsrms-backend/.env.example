NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/vsrms?retryWrites=true&w=majority

# ── Asgardeo (server-side only — NEVER expose these to the mobile app) ────────
ASGARDEO_ORG_NAME=your-org-name
ASGARDEO_CLIENT_ID=your-client-id
ASGARDEO_CLIENT_SECRET=your-client-secret

# Used by the JWT middleware to verify tokens from authenticated requests
ASGARDEO_ISSUER=https://api.asgardeo.io/t/your-org-name
ASGARDEO_JWKS_URL=https://api.asgardeo.io/t/your-org-name/oauth2/jwks
ASGARDEO_AUDIENCE=your-client-id

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# ── Cloudflare R2 (optional) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
